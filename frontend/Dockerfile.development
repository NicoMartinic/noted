FROM node:24.0.2-alpine

# DECLARE ARGUMENTS FOR BUILD
ARG PORT=3000
ARG BACKEND_URL

# CONFIGURE VARIABLES
ENV PORT=${PORT}
ENV BACKEND_URL=${BACKEND_URL}
ENV NODE_ENV=development

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (dev needs all deps)
RUN npm install

# Copy source code
COPY . .

EXPOSE ${PORT}

# Start Next.js in development mode with hot reload
CMD ["npm", "run", "dev"]
