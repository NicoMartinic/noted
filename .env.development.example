# ─── Django ────────────────────────────────────────────────────────────────────
# Must be ≥32 chars. Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=django-insecure-dev-key-replace-me-with-50-char-secret!!
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend

# ─── Database ──────────────────────────────────────────────────────────────────
DB_NAME=notes_db
DB_USER=notes_user
DB_PASSWORD=notes_password
DB_HOST=db
DB_PORT=5432

# ─── CORS / Cookies ────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000
COOKIE_SECURE=False
COOKIE_SAMESITE=Lax

# ─── Next.js proxy ─────────────────────────────────────────────────────────────
BACKEND_URL=http://backend:8000
PORT=3000

# ─── Error tracking (optional) ─────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/YYY
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/YYY
# HTTPS_ENABLED=0