# ─── Django ────────────────────────────────────────────────────────────────────
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CHANGE_ME_USE_A_STRONG_RANDOM_KEY_OF_50_PLUS_CHARS
DEBUG=0
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ─── Database ──────────────────────────────────────────────────────────────────
DB_NAME=notes_db
DB_USER=notes_user
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_HOST=db
DB_PORT=5432

# ─── CORS / Cookies ────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com
COOKIE_SECURE=True
COOKIE_SAMESITE=Strict

# ─── Next.js proxy ─────────────────────────────────────────────────────────────
BACKEND_URL=http://backend:8000
PORT=3000

# ─── Error tracking ────────────────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/YYY
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/YYY


#  ─── For Testing locally for prod ────────────────────────────────────────────────────────────────────

